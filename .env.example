SITE_DOMAIN=paperstride.duckdns.org
NEXT_PUBLIC_SITE_URL=https://paperstride.duckdns.org
NEXT_PUBLIC_CONTACT_EMAIL=hello@paperstride.org

# Local Ollama backend. Keep these server-only; do not expose them with NEXT_PUBLIC_.
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_FAST_MODEL=llama3.2:3b
LLM_MODEL=qwen2.5:7b-instruct
LLM_PASSAGE_MODEL=qwen2.5:7b-instruct
OLLAMA_NUM_THREAD=4
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=4096
